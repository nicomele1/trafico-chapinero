%	vim:foldmethod=marker filetype=tex

\newcommand{\mybar}{|}
\newlength{\dummylength}
\newcommand{\dummycommand}{}

\newcommand\upref[1]{{\upshape\ref{#1}}}
\newcommand\upeqref[1]{{\upshape\eqref{#1}}}

%%% Number sets
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\K}{\mathbb{K}}

%%% Traffic model spaces
\newcommand{\calP}{\mathcal{P}}
\newcommand{\calC}{\mathcal{C}}
\newcommand{\calB}{\mathcal{B}}
\newcommand{\calSO}{\mathcal{SO}}
\newcommand{\calI}{\mathcal{I}}

%%% Feasible set
\newcommand{\FeasSet}{\Omega}

%%% Traffic operators
\newcommand{\TC}{\mathrm{TC}}
\newcommand{\PoA}{\mathrm{PoA}}
\newcommand{\UE}{\mathrm{UE}}
\newcommand{\SO}{\mathrm{SO}}
\newcommand{\BPR}{\mathrm{BPR}}
\newcommand{\CMS}{\mathrm{CMS}}

%%% Graph notation
\newcommand{\tail}{\mathrm{tail}}
\newcommand{\head}{\mathrm{head}}

%%% Definition symbol
\newcommand{\defeq}{\coloneqq}

%%% Indicator
\newcommand{\ind}[1]{\mathbf{1}_{[#1]}}

%%% Norms and inner product
\newcommand{\norm}[1]{\left\|#1\right\|}
\newcommand{\abs}[1]{\left|#1\right|}
\newcommand{\inner}[2]{\left\langle #1,\, #2 \right\rangle}
